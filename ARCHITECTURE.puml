@startuml
title Locus Shell Current Architecture

package "shell/core\ncrate: shell_core" {
  class ShellApp {
    + with_scss(path)
    + watch_stylesheets(enabled)
    + run<Component>(init)
  }

  class WindowConfig
  class "source::Observable<T>" as Observable
  class "source::Subscriptions" as Subscriptions

  ShellApp --> WindowConfig
  Subscriptions --> Observable
}

package "shell/macros\ncrate: shell_macros" {
  class "#[model]" as ModelMacro {
    + plain model fields
    + source update messages
    + dirty tracking
    + subscription ownership
  }

  class "#[component]" as ComponentMacro {
    + starts Observable subscriptions
    + rewrites bind attributes
  }

  ModelMacro --> Observable
  ComponentMacro --> Subscriptions
}

package "consumer source modules" {
  class "locusfs source fn" as LocusSource {
    + window_title(String)
    + window_is_selected(String)
    + selected_workspace_windows()
  }

  class "other source fn" as OtherSource

  LocusSource --> Observable
  OtherSource --> Observable
}

package "rsynapse-shell\ncrate: rsynapse_shell" {
  class MainBar
  class ProjectLabel
  class WindowTile

  MainBar --> ProjectLabel
  MainBar --> WindowTile
  ProjectLabel --> LocusSource
  WindowTile --> LocusSource
}

database "locusfs" as Locusfs

LocusSource --> Locusfs : observable LocusPath sources
ModelMacro --> ComponentMacro

@enduml
