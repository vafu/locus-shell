#!/usr/bin/env sh
set -eu

usage() {
    echo "usage: $0 check|generate" >&2
}

if [ "$#" -ne 1 ]; then
    usage
    exit 2
fi

command="$1"
case "$command" in
    check|generate) ;;
    *)
        usage
        exit 2
        ;;
esac

repo_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
locus_repo=${LOCUS_REPO:-"$repo_root/../locus"}
schema=${LOCUS_SCHEMA:-"$locus_repo/schema.yaml"}
generated="$repo_root/locus-graph/src/generated.rs"

if [ -n "${LOCUS_CODEGEN:-}" ]; then
    codegen="$LOCUS_CODEGEN"
elif [ -x "$locus_repo/target/debug/locus-codegen" ]; then
    codegen="$locus_repo/target/debug/locus-codegen"
elif [ -x "$locus_repo/target/release/locus-codegen" ]; then
    codegen="$locus_repo/target/release/locus-codegen"
else
    echo "locus-codegen not found; build it in $locus_repo or set LOCUS_CODEGEN" >&2
    exit 1
fi

case "$command" in
    generate)
        "$codegen" --schema "$schema" --language rust --out "$generated"
        rustfmt "$generated"
        ;;
    check)
        tmp=$(mktemp)
        trap 'rm -f "$tmp"' EXIT
        "$codegen" --schema "$schema" --language rust --out "$tmp"
        rustfmt "$tmp"
        diff -u "$generated" "$tmp"
        ;;
esac
